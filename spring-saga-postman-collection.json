{
  "info": {
    "_postman_id": "spring-saga-collection-v2",
    "name": "Spring Saga - All Services",
    "description": "Test collection for Spring Saga microservices (Spring Boot 3.2.5 + Axon Framework).\n\n**PREREQUISITE:** Start all services before running:\n1. Axon Server (Docker): cd Axon-Server && docker compose up -d\n2. ProductService  : port 8081\n3. OrderService    : port 9091\n4. UserService     : port 9092\n5. PaymentService  : port 9093 (event-driven, no REST)\n6. ShipmentService : port 9094 (event-driven, no REST)\n\n**Axon Server dashboard:** http://localhost:8024\n\n**Recommended run order:**\n1. ProductService - Create Product   (saves productId to variable)\n2. ProductService - Get All Products\n3. UserService    - Get User Payment Details\n4. OrderService   - Create Order     (uses saved productId)\n5. Run the E2E folder in sequence for the full saga flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "productServiceUrl", "value": "http://localhost:8081", "type": "string" },
    { "key": "orderServiceUrl",   "value": "http://localhost:9091", "type": "string" },
    { "key": "userServiceUrl",    "value": "http://localhost:9092", "type": "string" },
    { "key": "productId",         "value": "",                      "type": "string", "description": "Populated automatically by 'Create Product' test script" },
    { "key": "userId",            "value": "user-001",              "type": "string" },
    { "key": "addressId",         "value": "address-001",           "type": "string" }
  ],
  "item": [
    {
      "name": "1 - ProductService (port 8081)",
      "item": [
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"iPhone 15 Pro\",\n  \"price\": 999.99,\n  \"quantity\": 100\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{productServiceUrl}}/products",
              "host": ["{{productServiceUrl}}"],
              "path": ["products"]
            },
            "description": "Creates a new product via Axon CreateProductCommand.\n\nReturns: plain UUID string (the generated productId).\n\nThe test script saves the productId as a collection variable for use in Create Order."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns a UUID productId', function () {",
                  "    var productId = pm.response.text().replace(/\"/g, '').trim();",
                  "    pm.expect(productId).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "    pm.collectionVariables.set('productId', productId);",
                  "    console.log('Saved productId:', productId);",
                  "});",
                  "",
                  "pm.test('Response time < 5000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(5000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product - Budget Item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"USB-C Cable\",\n  \"price\": 9.99,\n  \"quantity\": 500\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{productServiceUrl}}/products",
              "host": ["{{productServiceUrl}}"],
              "path": ["products"]
            },
            "description": "Creates a second product to populate the catalogue."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returns a UUID productId', function () {",
                  "    var productId = pm.response.text().replace(/\"/g, '').trim();",
                  "    pm.expect(productId).to.match(/^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$/i);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{productServiceUrl}}/products",
              "host": ["{{productServiceUrl}}"],
              "path": ["products"]
            },
            "description": "Returns all products from the JPA read model via Axon QueryGateway (GetProductsQuery).\n\nResponse: array of { name, price, quantity }\n\nNote: run 'Create Product' first so the list is non-empty."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is a JSON array', function () {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Products have expected fields', function () {",
                  "    var products = pm.response.json();",
                  "    if (products.length > 0) {",
                  "        pm.expect(products[0]).to.have.property('name');",
                  "        pm.expect(products[0]).to.have.property('price');",
                  "        pm.expect(products[0]).to.have.property('quantity');",
                  "    }",
                  "});",
                  "",
                  "pm.test('Response time < 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2 - UserService (port 9092)",
      "item": [
        {
          "name": "Get User Payment Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userServiceUrl}}/users/{{userId}}",
              "host": ["{{userServiceUrl}}"],
              "path": ["users", "{{userId}}"]
            },
            "description": "Returns payment details for the given userId via Axon QueryGateway (GetUserPaymentDetailsQuery).\n\nThe UserProjection returns hardcoded demo data:\n- firstName: Qiang, lastName: Li\n- cardNumber: 123456789, cvv: 111, validUntilYear: 2028\n\nAny userId value will return data (userId is echoed back).\n\nResponse shape:\n{\n  \"userId\": \"user-001\",\n  \"firstName\": \"Qiang\",\n  \"lastName\": \"Li\",\n  \"cardDetails\": {\n    \"name\": \"Qiang Li\",\n    \"cardNumber\": \"123456789\",\n    \"validUntilMonth\": 5,\n    \"validUntilYear\": 2028,\n    \"cvv\": 111\n  }\n}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has all user fields', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('userId');",
                  "    pm.expect(json).to.have.property('firstName');",
                  "    pm.expect(json).to.have.property('lastName');",
                  "    pm.expect(json).to.have.property('cardDetails');",
                  "});",
                  "",
                  "pm.test('userId echoes the path variable', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.userId).to.eql(pm.collectionVariables.get('userId'));",
                  "});",
                  "",
                  "pm.test('CardDetails has all required fields', function () {",
                  "    var card = pm.response.json().cardDetails;",
                  "    pm.expect(card).to.have.property('name');",
                  "    pm.expect(card).to.have.property('cardNumber');",
                  "    pm.expect(card).to.have.property('validUntilMonth');",
                  "    pm.expect(card).to.have.property('validUntilYear');",
                  "    pm.expect(card).to.have.property('cvv');",
                  "});",
                  "",
                  "pm.test('Response time < 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get User Payment Details - Arbitrary userId",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userServiceUrl}}/users/custom-user-999",
              "host": ["{{userServiceUrl}}"],
              "path": ["users", "custom-user-999"]
            },
            "description": "Demonstrates that any userId returns data (demo projection, not DB-backed)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('userId is echoed back', function () {",
                  "    pm.expect(pm.response.json().userId).to.eql('custom-user-999');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "3 - OrderService (port 9091)",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"userId\": \"{{userId}}\",\n  \"addressId\": \"{{addressId}}\",\n  \"quantity\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{orderServiceUrl}}/orders",
              "host": ["{{orderServiceUrl}}"],
              "path": ["orders"]
            },
            "description": "Creates an order and triggers the Order Processing Saga.\n\nReturns: plain string 'Order Created'\n\nSaga flow (async after response):\n1. OrderCreatedEvent published\n2. OrderProcessingSaga starts → ValidatePaymentCommand → PaymentService\n3. PaymentService → PaymentProcessedEvent or PaymentCancelledEvent\n4. If payment OK → ShipOrderCommand → ShipmentService\n5. ShipmentService → OrderShippedEvent\n6. Saga → CompleteOrderCommand → OrderService\n\nPREREQUISITE: Run 'Create Product' first to populate {{productId}}, or paste a real productId into the request body."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is \"Order Created\"', function () {",
                  "    var body = pm.response.text().replace(/\"/g, '').trim();",
                  "    pm.expect(body).to.eql('Order Created');",
                  "});",
                  "",
                  "pm.test('Response time < 10000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(10000);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Order - Hardcoded productId",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"PASTE_PRODUCT_ID_HERE\",\n  \"userId\": \"user-001\",\n  \"addressId\": \"address-002\",\n  \"quantity\": 2\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{orderServiceUrl}}/orders",
              "host": ["{{orderServiceUrl}}"],
              "path": ["orders"]
            },
            "description": "Alternative order request with an inline productId.\nReplace PASTE_PRODUCT_ID_HERE with a UUID returned by Create Product."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is \"Order Created\"', function () {",
                  "    var body = pm.response.text().replace(/\"/g, '').trim();",
                  "    pm.expect(body).to.eql('Order Created');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "4 - End-to-End Saga Flow",
      "description": "Run all 4 steps IN ORDER to exercise the complete Order Saga across all services.\n\nStep 1 saves {{productId}} so Step 4 can use it automatically.",
      "item": [
        {
          "name": "Step 1 - Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"MacBook Pro M3\",\n  \"price\": 1999.00,\n  \"quantity\": 50\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{productServiceUrl}}/products",
              "host": ["{{productServiceUrl}}"],
              "path": ["products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E Step 1] Product created', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var productId = pm.response.text().replace(/\"/g, '').trim();",
                  "    pm.expect(productId).to.match(/^[0-9a-f-]{36}$/i);",
                  "    pm.collectionVariables.set('productId', productId);",
                  "    console.log('Step 1 - productId:', productId);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 2 - Verify Product in Catalogue",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{productServiceUrl}}/products",
              "host": ["{{productServiceUrl}}"],
              "path": ["products"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E Step 2] Product catalogue non-empty', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var products = pm.response.json();",
                  "    pm.expect(products).to.be.an('array').with.length.greaterThan(0);",
                  "    console.log('Step 2 - Total products:', products.length);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 3 - Verify User & Payment Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{userServiceUrl}}/users/{{userId}}",
              "host": ["{{userServiceUrl}}"],
              "path": ["users", "{{userId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E Step 3] UserService returns user with card', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('userId');",
                  "    pm.expect(json).to.have.property('cardDetails');",
                  "    console.log('Step 3 - User:', json.firstName, json.lastName);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Step 4 - Create Order / Trigger Saga",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"userId\": \"{{userId}}\",\n  \"addressId\": \"{{addressId}}\",\n  \"quantity\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{orderServiceUrl}}/orders",
              "host": ["{{orderServiceUrl}}"],
              "path": ["orders"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('[E2E Step 4] Order saga triggered successfully', function () {",
                  "    pm.response.to.have.status(200);",
                  "    var body = pm.response.text().replace(/\"/g, '').trim();",
                  "    pm.expect(body).to.eql('Order Created');",
                  "    console.log('Step 4 - Saga triggered for productId:', pm.collectionVariables.get('productId'));",
                  "    console.log('Check Axon Server dashboard at http://localhost:8024 to trace saga execution.');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "5 - Negative / Edge Cases",
      "description": "Requests that test error handling and boundary conditions.",
      "item": [
        {
          "name": "Create Order - Empty productId",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"\",\n  \"userId\": \"user-001\",\n  \"addressId\": \"address-001\",\n  \"quantity\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{orderServiceUrl}}/orders",
              "host": ["{{orderServiceUrl}}"],
              "path": ["orders"]
            },
            "description": "Sends an order with an empty productId. Expected: non-200 or an error response from the saga."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Empty productId returns error or 500', function () {",
                  "    pm.expect(pm.response.code).to.not.equal(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
